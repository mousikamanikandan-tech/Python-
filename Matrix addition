r = int(input("Rows: "))
c = int(input("Columns: "))

print("Enter matrix 1:")
A = [[int(input()) for _ in range(c)] for _ in range(r)]

print("Enter matrix 2:")
B = [[int(input()) for _ in range(c)] for _ in range(r)]

result = [[A[i][j] + B[i][j] for j in range(c)] for i in range(r)]

print("Result:")
for row in result:
    print(row)
